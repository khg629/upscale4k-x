{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "dialog:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/realesrgan",
          "sidecar": true,
          "args": [
            "-i", { "validator": "\\S+" },
            "-o", { "validator": "\\S+" },
            "-n", { "validator": "[\\w\\-]+" },
            "-s", { "validator": "[1-9]" },
            "-m", { "validator": "\\S+" }
          ]
        }
      ]
    }
  ]
}
